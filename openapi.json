  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "entityId": {
            "type": "integer"
          },
          "incrementId": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "new",
              "pending_payment",
              "processing",
              "complete",
              "closed",
              "canceled",
